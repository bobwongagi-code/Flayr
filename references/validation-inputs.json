{
  "schema_version": 4,
  "description": "Flayr 从零验证输入清单。primary 用于主回归；已参与规则讨论的历史 holdout 已降级为 seen_validation，不得用于最终泛化验收。产品级 GT 统计必须先通过锁定事实的 comparison_eligibility 审计。",
  "comparison_eligibility_policy": {
    "product_gt_scopes": [
      "same_product",
      "comparable_variant"
    ],
    "cross_product_scope": "S1/S6 可作结构参考，S2-S5 不纳入产品级 GT、差距或改进统计",
    "same_task_structure_scope": "仅运营显式确认的同类同任务、非同 SKU 样本可用；允许 S1-S4/S6 的结构执行 GT，禁止比较具体配方、参数、品牌或功效优劣，S5 默认不纳入",
    "pending_scope": "未经当前 facts 审计的样本不得进入产品级指标"
  },
  "blind_validation_contract": {
    "minimum_samples": 12,
    "group": "blind",
    "evaluation_scopes": {
      "stage_severity": "默认范围。人工必须在模型结果打开前填写 S1-S6 的差距等级，进入阶段准确率统计。",
      "whole_video_observation": "只冻结人工对整条内容是否具备观看与带货竞争力的裁决；不伪造 S1-S6 标签，不进入阶段准确率或 blind 样本数量统计。"
    },
    "admission": [
      "视频对不得出现在 primary、calibration、seen_validation 或任何用于规则设计的历史 run 中",
      "每对必须提供 benchmark_video、creator_video、product_name、product_category、target_market；产品级比较仍须通过 comparison_eligibility 审计",
      "每个阶段的人工 GT 必须在本轮规则冻结后、模型结果打开前完成",
      "必须用 manage_validation_cohort.py 冻结视频、GT、代码、prompt/schema 与模型配置哈希",
      "结果一旦打开或用于修改规则，cohort 必须标记 spent，样本降级为 seen_validation"
    ],
    "required_ground_truth": {
      "partition": "blind",
      "stages": [
        "S1",
        "S2",
        "S3",
        "S4",
        "S5",
        "S6"
      ],
      "severity_values": [
        "small",
        "medium",
        "large"
      ],
      "stage_oracles": [
        "creator_execution",
        "benchmark_execution",
        "relation",
        "decision_event_ids",
        "reason",
        "confidence"
      ],
      "decision_gt": [
        "top_root_causes"
      ]
    }
  },
